NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://stok_user:stok_pass@localhost:5432/stok_db
CORS_ORIGIN=http://localhost:5173

# JWT - Production'da mutlaka guclu, rastgele degerler kullanin
# openssl rand -base64 48 komutu ile uretebilirsiniz
JWT_SECRET=
JWT_REFRESH_SECRET=

# Google OAuth - Google Cloud Console'dan alin
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback
FRONTEND_URL=http://localhost:5173

# E-posta Ayarlari
# Resend API (production icin tavsiye edilir - https://resend.com)
# RESEND_API_KEY=re_xxxxxxxxxxxx
# EMAIL_FROM=StokPro <noreply@stoksayac.com>

# SMTP (lokal gelistirme icin, bos birakilirsa e-postalar konsola yazilir)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=StokSayaç <noreply@stoksayac.com>

# Super Admin - Production'da guclu bir sifre kullanin
SUPER_ADMIN_EMAIL=admin@stoksayac.com
SUPER_ADMIN_PASSWORD=

# Admin API Key - Health debug endpointleri icin (sadece development)
ADMIN_API_KEY=
